# 服务端口
PORT=5173

# 推荐先用阿里云百炼 OpenAI 兼容接口；也可以换成其他兼容 OpenAI Chat Completions 的供应商。
# 阿里云百炼华北2北京：
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_API_KEY=替换成你的API_KEY

# 也支持这些环境变量名，优先级低于 LLM_API_KEY：
# DASHSCOPE_API_KEY=替换成你的阿里云百炼API_KEY
# OPENAI_API_KEY=替换成你的OpenAI_API_KEY
