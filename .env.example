# 服务端口
PORT=5173

# 默认接入 DeepSeek OpenAI 兼容接口。
# 不建议把真实 key 写进项目文件；本项目默认会读取 /Users/lyric/key/api-key。
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# 可选：如果不用 /Users/lyric/key/api-key，可用环境变量覆盖。
# LLM_API_KEY=替换成你的DeepSeek API_KEY
# DEEPSEEK_API_KEY=替换成你的DeepSeek API_KEY
# DEEPSEEK_API_KEY_FILE=/Users/lyric/key/api-key

# 阿里云 DashScope / Qwen TTS API Key 也不要写进项目文件；本项目默认会读取：
# /Users/lyric/key/ali-key
# 可选覆盖：
# DASHSCOPE_API_KEY=替换成你的阿里云DashScope API_KEY
# ALIYUN_API_KEY=替换成你的阿里云DashScope API_KEY
# ALIYUN_API_KEY_FILE=/Users/lyric/key/ali-key
# ALIYUN_TTS_MODEL=qwen3-tts-flash
# ALIYUN_TTS_VOICE=Cherry
